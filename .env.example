# 이 파일을 복사해서 `.env.local` 로 만들고, 실제 값을 채워 넣으세요.
#   cp .env.example .env.local
# `.env.local` / `.env` 는 .gitignore 로 저장소에 올라가지 않습니다. 절대 커밋하지 마세요.
#
# 값이 비어 있으면 그 값을 필요로 하는 MCP 서버만 등록에서 건너뜁니다.
# GitHub / Lazyweb 처럼 OAuth 로 붙는 서버는 여기에 적을 것이 없고,
# 최초 사용 시 각 도구에서 로그인하면 됩니다.

# Exa 웹 검색 API 키 — https://exa.ai 에서 발급
EXA_API_KEY=

# Filesystem MCP 가 접근을 허용할 디렉터리 (절대경로)
# 비워두면 filesystem 서버는 등록되지 않습니다.
FILESYSTEM_DIR=
